@article{MarinaAndreasRudy2025empower,
author = {Nacka, Marina and Drichoutis, Andreas C. and Nayga Jr., Rodolfo M.},
title = {Women's Empowerment and Intra-Household Bargaining Power},
journal = {Review of Development Economics},
volume = {30},
number = {3},
pages = {1643-1656},
keywords = {agricultural households, allocation task, A-WEAI, dictator game},
doi = {https://doi.org/10.1111/rode.70077},
url = {https://onlinelibrary.wiley.com/doi/abs/10.1111/rode.70077},
eprint = {https://onlinelibrary.wiley.com/doi/pdf/10.1111/rode.70077},
abstract = {ABSTRACT We assess the effectiveness of the Abbreviated Women's Empowerment in Agriculture Index (A-WEAI) in predicting intra-household bargaining power. We conducted a lab-in-the-field experiment with agricultural households, where spouses made decisions about money allocations. The experiment tested whether they would choose efficient overall household gains or favor individual monetary benefits. Our findings demonstrate that women's empowerment levels, as measured by the A-WEAI, are predictive of decisions in the allocation task. This supports the A-WEAI's utility in representing and predicting intra-household dynamics.},
year = {2026}
}



